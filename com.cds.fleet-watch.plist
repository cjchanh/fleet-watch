<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cds.fleet-watch</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/cj/.local/bin/fleet</string>
        <string>discover</string>
    </array>
    <key>StartInterval</key>
    <integer>60</integer>
